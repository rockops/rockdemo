{
  "name": "rockdemo",
  "displayName": "rockDemo",
  "description": "Run Killercoda-style markdown scenarios as live demos in VS Code.",
  "version": "1.2.0",
  "publisher": "RockOps",
  "license": "Apache-2.0",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/rockops/rockdemo.git"
  },
  "bugs": {
    "url": "https://github.com/rockops/rockdemo/issues"
  },
  "homepage": "https://github.com/rockops/rockdemo#readme",
  "keywords": [
    "killercoda",
    "demo",
    "markdown",
    "tutorial",
    "docker"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "configuration": {
      "title": "rockDemo",
      "properties": {
        "rockdemo.restoreSidebar": {
          "type": "boolean",
          "default": true,
          "description": "Restore the primary sidebar (Explorer) when exiting demo mode or ending a scenario."
        },
        "rockdemo.restorePanel": {
          "type": "boolean",
          "default": true,
          "description": "Restore the bottom panel (Terminal) when exiting demo mode or ending a scenario."
        },
        "rockdemo.restoreAgentPanel": {
          "type": "boolean",
          "default": true,
          "description": "Restore the agent panel (Auxiliary Bar) when exiting demo mode or ending a scenario."
        },
        "rockdemo.scenarioLayout": {
          "type": "string",
          "enum": [
            "vertical",
            "horizontal"
          ],
          "default": "vertical",
          "description": "The layout orientation of the scenario instructions and node terminals. 'vertical' places instructions on the left and terminals on the right; 'horizontal' places instructions on the top and terminals on the bottom."
        },
        "rockdemo.clearTerminalOnReady": {
          "type": "boolean",
          "default": true,
          "description": "Clear the terminal window to start clean when the shell is available and all startup/foreground scripts have finished."
        }
      }
    },
    "commands": [
      {
        "command": "rockdemo.exec",
        "title": "rockDemo: Run in terminal"
      },
      {
        "command": "rockdemo.copy",
        "title": "rockDemo: Copy command"
      },
      {
        "command": "rockdemo.open",
        "title": "rockDemo: Open file"
      },
      {
        "command": "rockdemo.preview",
        "title": "rockDemo: Run demo",
        "icon": "$(play-circle)"
      },
      {
        "command": "rockdemo.stop",
        "title": "rockDemo: Stop demo",
        "icon": "$(debug-stop)"
      },
      {
        "command": "rockdemo.stopAndClearCache",
        "title": "rockDemo: Stop and clear image cache"
      },
      {
        "command": "rockdemo.clearCache",
        "title": "rockDemo: Clear image cache"
      },
      {
        "command": "rockdemo.newNodeTerminal",
        "title": "rockDemo: New terminal on node",
        "icon": "$(add)"
      }
    ],
    "terminal": {
      "profiles": [
        {
          "id": "rockdemo.nodeTerminal",
          "title": "rockDemo: Node Shell",
          "icon": "$(server-process)"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "rockdemo.preview",
          "when": "editorLangId == markdown && !rockdemo.scenarioRunning",
          "group": "navigation@-1"
        },
        {
          "command": "rockdemo.preview",
          "when": "resourceFilename == index.json && !rockdemo.scenarioRunning",
          "group": "navigation@-1"
        },
        {
          "command": "rockdemo.stop",
          "when": "rockdemo.scenarioRunning",
          "group": "navigation@-1"
        },
        {
          "command": "rockdemo.stop",
          "when": "activeWebviewPanelId == 'rockdemo.demo'",
          "group": "navigation@-1"
        },
        {
          "command": "rockdemo.stopAndClearCache",
          "when": "rockdemo.scenarioRunning",
          "group": "1_rockdemo@1"
        },
        {
          "command": "rockdemo.newNodeTerminal",
          "when": "activeEditor == 'terminalEditor' && rockdemo.scenarioRunning",
          "group": "navigation@-1"
        }
      ],
      "terminal/title/context": [
        {
          "command": "rockdemo.newNodeTerminal",
          "when": "rockdemo.scenarioRunning",
          "group": "navigation@1"
        }
      ],
      "commandPalette": [
        {
          "command": "rockdemo.exec",
          "when": "false"
        },
        {
          "command": "rockdemo.copy",
          "when": "false"
        },
        {
          "command": "rockdemo.open",
          "when": "false"
        },
        {
          "command": "rockdemo.stop",
          "when": "false"
        },
        {
          "command": "rockdemo.stopAndClearCache",
          "when": "rockdemo.scenarioRunning"
        },
        {
          "command": "rockdemo.newNodeTerminal",
          "when": "rockdemo.scenarioRunning"
        }
      ]
    }
  }
}
